# Copy this file to `.env` (gitignored, never commit the real token):
#   cp .env.example .env
#
# Paste the tunnel token from the Cloudflare Zero Trust dashboard:
#   Zero Trust -> Networks -> Tunnels -> <your tunnel> -> Overview ->
#   "Install and run a connector" -> copy the token value out of the
#   `cloudflared tunnel run --token <TOKEN>` command shown there.
TUNNEL_TOKEN=
